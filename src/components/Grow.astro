---
---

<section class="grow">
  <div class="container">
    <div class="content">
      <h2>READY TO GROW YOUR BUSINESS?</h2>
      <p>Get in touch with our team today and let's discuss how we can help you reach more customers.</p>
      <button class="cta-button">GET STARTED</button>
    </div>
  </div>
</section>

<style>
  .grow {
    background: linear-gradient(rgba(240, 235, 216, 0.85), rgba(240, 235, 216, 0.85)), 
                url('https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=1600&h=400&fit=crop') center/cover;
    padding: 100px 20px;
    font-family: "DM Sans", sans-serif;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .content {
    border: 2px solid white;
    padding: 60px 50px;
    border-radius: 4px;
  }

  h2 {
    color: white;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 20px;
    letter-spacing: 0.5px;
  }

  p {
    color: white;
    line-height: 1.6;
    margin-bottom: 32px;
    font-size: 16px;
  }

  .cta-button {
    padding: 14px 32px;
    background: white;
    border: none;
    color: #1a3a52;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    border-radius: 2px;
  }

  .cta-button:hover {
    background: #f0f0f0;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 768px) {
    .grow {
      padding: 80px 20px;
    }

    .content {
      padding: 40px 30px;
    }

    h2 {
      font-size: 24px;
    }

    p {
      font-size: 15px;
    }
  }
</style>

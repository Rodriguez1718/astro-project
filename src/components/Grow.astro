<section
  class="relative py-[80px] md:py-[100px] font-['DM_Sans',sans-serif] overflow-hidden">
  <img src="https://pngimg.com/d/world_map_PNG2.png" alt="" class="absolute w-full backdrop-blur-2xl" id="parallax-img-3">

  <div class="relative max-w-[800px] mx-auto text-center z-10">
    <div class="px-[30px] py-[40px] md:px-[50px] md:py-[60px] rounded-[4px]">

      <h2 class="text-black text-[24px] md:text-[92px] font-bold leading-[1.3] mb-[20px] tracking-[0.5px] font-['Playfair_Display',sans-serif]">
        READY TO GROW YOUR BUSINESS?
      </h2>

      <p class="text-black leading-[1.6] mb-[32px] text-[15px] md:text-[16px]">
        Get in touch with our team today and let's discuss how we can help you reach more customers.
      </p>

      <button class="px-[32px] py-[14px] bg-black border-none text-[white] font-semibold text-[13px] tracking-[0.5px] cursor-pointer transition-all duration-300 uppercase rounded-[2px] hover:bg-[#f0f0f0] hover:text-[black] hover:-translate-y-[2px] hover:shadow-[0_4px_12px_rgba(255,255,255,0.3)]">
        GET STARTED
      </button>

    </div>
  </div>
</section>
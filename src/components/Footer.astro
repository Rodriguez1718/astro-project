---
---

<footer class="bg-[#C4A05A] text-white pt-[60px] pb-[30px] px-[20px] font-['DM_Sans',sans-serif]">
  <div class="max-w-[1200px] mx-auto">

    <!-- Top Section -->
    <div class="flex flex-col md:flex-row justify-between gap-[40px] md:gap-[60px] pb-[50px] border-b border-white/20 mb-[40px]">

      <!-- Brand -->
      <div class="flex-1 max-w-[400px]">
        <div class="flex items-center gap-[12px] mb-[20px]">
            <a href="/" class="logo">
                <img src="https://ntv-template-5.vercel.app/logo/dealer-logo.avif"
                    class="w-[48px] h-[48px] max-w-[48px] max-h-[48px]" />
            </a>
        </div>
        <p class="text-white/80 leading-[1.7] text-[14px]">
          Your trusted partner for comprehensive digital marketing solutions—from
          custom website design and SEO to indoor billboard advertising and targeted
          campaigns that deliver real results.
        </p>
      </div>

      <!-- Social -->
      <div>
        <h3 class="text-[12px] font-bold tracking-[1px] mb-[20px]">CONNECT WITH US</h3>
        <div class="flex gap-[12px]">
          <a href="#" aria-label="LinkedIn" class="w-[40px] h-[40px] bg-white/10 rounded-[4px] flex items-center justify-center text-white transition-all duration-300 hover:bg-white/20 hover:-translate-y-[2px]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          </a>
          <a href="#" aria-label="Facebook" class="w-[40px] h-[40px] bg-white/10 rounded-[4px] flex items-center justify-center text-white transition-all duration-300 hover:bg-white/20 hover:-translate-y-[2px]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
          </a>
          <a href="#" aria-label="Instagram" class="w-[40px] h-[40px] bg-white/10 rounded-[4px] flex items-center justify-center text-white transition-all duration-300 hover:bg-white/20 hover:-translate-y-[2px]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="#" aria-label="YouTube" class="w-[40px] h-[40px] bg-white/10 rounded-[4px] flex items-center justify-center text-white transition-all duration-300 hover:bg-white/20 hover:-translate-y-[2px]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Links Section -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-[30px] md:gap-[40px] mb-[40px]">

      <!-- Solutions -->
      <div>
        <h4 class="text-[12px] font-bold tracking-[1px] mb-[20px]">SOLUTIONS</h4>
        <details class="mb-[12px] group">
          <summary class="cursor-pointer text-[13px] font-semibold py-[8px] list-none flex items-center gap-[8px] [&::-webkit-details-marker]:hidden after:content-['›'] after:text-[18px] after:transition-transform group-open:after:rotate-90">
            FOUNDATIONAL
          </summary>
          <ul class="pl-[16px] mt-[8px] list-none p-0 m-0">
            <li class="mb-[12px] text-[14px] text-white/80"><a href="#" class="text-white/80 no-underline transition-colors duration-300 hover:text-white">Website Design</a></li>
            <li class="mb-[12px] text-[14px] text-white/80"><a href="#" class="text-white/80 no-underline transition-colors duration-300 hover:text-white">Google Business Profile</a></li>
            <li class="mb-[12px] text-[14px] text-white/80"><a href="#" class="text-white/80 no-underline transition-colors duration-300 hover:text-white">Social Media Management</a></li>
          </ul>
        </details>
        <details class="mb-[12px] group">
          <summary class="cursor-pointer text-[13px] font-semibold py-[8px] list-none flex items-center gap-[8px] [&::-webkit-details-marker]:hidden after:content-['›'] after:text-[18px] after:transition-transform group-open:after:rotate-90">
            LEAD GENERATION
          </summary>
        </details>
        <details class="mb-[12px] group">
          <summary class="cursor-pointer text-[13px] font-semibold py-[8px] list-none flex items-center gap-[8px] [&::-webkit-details-marker]:hidden after:content-['›'] after:text-[18px] after:transition-transform group-open:after:rotate-90">
            BRANDING & AWARENESS
          </summary>
        </details>
      </div>

      <!-- Indoor Billboards -->
      <div>
        <h4 class="text-[12px] font-bold tracking-[1px] mb-[20px]">INDOOR BILLBOARDS</h4>
        <ul class="list-none p-0 m-0">
          <li class="mb-[12px] text-[14px] text-white/80"><a href="#" class="text-white/80 no-underline transition-colors duration-300 hover:text-white">Become a Venue Partner</a></li>
          <li class="mb-[12px] text-[14px] text-white/80"><a href="#" class="text-white/80 no-underline transition-colors duration-300 hover:text-white">Locations</a></li>
          <li class="mb-[12px] text-[14px] text-white/80"><a href="#" class="text-white/80 no-underline transition-colors duration-300 hover:text-white">Screen Advertising</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-[12px] font-bold tracking-[1px] mb-[20px]">COMPANY</h4>
        <ul class="list-none p-0 m-0">
          <li class="mb-[12px] text-[14px] text-white/80"><a href="#" class="text-white/80 no-underline transition-colors duration-300 hover:text-white">About</a></li>
          <li class="mb-[12px] text-[14px] text-white/80"><a href="#" class="text-white/80 no-underline transition-colors duration-300 hover:text-white">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-[12px] font-bold tracking-[1px] mb-[20px]">CONTACT US</h4>
        <ul class="list-none p-0 m-0">
          <li class="mb-[12px] text-[14px] text-white/80">Your City, State</li>
          <li class="mb-[12px] text-[14px] text-white/80"><a href="tel:555-123-4567" class="text-white/80 no-underline transition-colors duration-300 hover:text-white">(555) 123-4567</a></li>
          <li class="mb-[12px] text-[14px] text-white/80"><a href="mailto:hello@yourbusiness.com" class="text-white/80 no-underline transition-colors duration-300 hover:text-white">hello@yourbusiness.com</a></li>
        </ul>
      </div>

    </div>

    <!-- Bottom Section -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-[16px] pt-[30px] border-t border-white/20 text-[13px] text-white/60 text-center">
      <div class="flex gap-[12px] items-center">
        <a href="#" class="text-white/60 no-underline transition-colors duration-300 hover:text-white">Terms</a>
        <span>|</span>
        <a href="#" class="text-white/60 no-underline transition-colors duration-300 hover:text-white">Privacy Policy</a>
      </div>
      <div>Made by Dealer Template · All rights reserved.</div>
    </div>

  </div>
</footer>
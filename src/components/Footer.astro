<style>
  .footer {
    background: #C4A05A;
    color: white;
    padding: 60px 20px 30px;
    font-family: "DM Sans", sans-serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .top-section {
    display: flex;
    justify-content: space-between;
    gap: 60px;
    padding-bottom: 50px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    margin-bottom: 40px;
  }

  .brand-section {
    flex: 1;
    max-width: 400px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .logo span {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1px;
  }

  .description {
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.7;
    font-size: 14px;
  }

  .social-section h3 {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }

  .social-links {
    display: flex;
    gap: 12px;
  }

  .social-links a {
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s ease;
  }

  .social-links a:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .links-section {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    margin-bottom: 40px;
  }

  .column h4 {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }

  .column ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .column ul li {
    margin-bottom: 12px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.8);
  }

  .column ul li a {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .column ul li a:hover {
    color: white;
  }

  details {
    margin-bottom: 12px;
  }

  summary {
    cursor: pointer;
    font-size: 13px;
    font-weight: 600;
    padding: 8px 0;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: '›';
    font-size: 18px;
    transition: transform 0.3s ease;
  }

  details[open] summary::after {
    transform: rotate(90deg);
  }

  details ul {
    padding-left: 16px;
    margin-top: 8px;
  }

  .bottom-section {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
  }

  .legal-links {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .legal-links a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .legal-links a:hover {
    color: white;
  }

  @media (max-width: 968px) {
    .top-section {
      flex-direction: column;
      gap: 40px;
    }

    .links-section {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }

    .bottom-section {
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
  }

  @media (max-width: 568px) {
    .links-section {
      grid-template-columns: 1fr;
    }
  }
</style>

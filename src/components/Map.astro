---
---

<section class="bg-[#FFFDF1] py-[80px] px-[20px] font-['DM_Sans',sans-serif]">
  <div class="max-w-[1200px] mx-auto">

    <!-- Header -->
    <div class="mb-[40px]">
      <h2 class="font-['Playfair_Display',serif] text-[32px] md:text-[42px] text-[#1a3a52] mb-[12px] font-bold">
        We Put Local Brands on the Map
      </h2>
      <p class="text-[#666] text-[16px]">
        Our <strong>network</strong> spans across Denver's most popular neighborhoods and venues
      </p>
    </div>

    <!-- Map Container -->
    <div class="flex flex-col md:flex-row gap-0 bg-white rounded-[8px] overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.1)] min-h-[500px]">

      <!-- Map -->
      <div class="flex-[2] relative min-h-[400px] md:min-h-[500px]">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d196281.09457062354!2d-105.02270839999999!3d39.7643389!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x876b80aa231f17cf%3A0x118ef4f8278a36d6!2sDenver%2C%20CO!5e0!3m2!1sen!2sus!4v1234567890123!5m2!1sen!2sus"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="absolute inset-0 w-full h-full">
        </iframe>
      </div>

      <!-- Locations Panel -->
      <div class="flex-1 px-[30px] py-[40px] bg-white border-t md:border-t-0 md:border-l border-[#e0e0e0]">
        <h3 class="text-[18px] font-bold mb-[8px] text-black tracking-[0.5px]">
          OUR LOCATIONS
        </h3>
        <p class="text-[#666] text-[14px] mb-[30px] leading-[1.5]">
          Browse the venues in our network while exploring the map.
        </p>

        <div class="flex flex-col gap-[20px]">

          <!-- Aurora -->
          <div class="flex items-center gap-[12px] p-[12px] border border-[#e0e0e0] rounded-[4px] cursor-pointer transition-all duration-300 hover:bg-[#f5f5f5] hover:border-[#4285F4]">
            <div class="flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="#4285F4"/>
              </svg>
            </div>
            <span class="text-[15px] text-[#333] font-medium">Aurora</span>
          </div>

          <!-- Lakewood -->
          <div class="flex items-center gap-[12px] p-[12px] border border-[#e0e0e0] rounded-[4px] cursor-pointer transition-all duration-300 hover:bg-[#f5f5f5] hover:border-[#4285F4]">
            <div class="flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="#4285F4"/>
              </svg>
            </div>
            <span class="text-[15px] text-[#333] font-medium">Lakewood</span>
          </div>

          <!-- Arvada -->
          <div class="flex items-center gap-[12px] p-[12px] border border-[#e0e0e0] rounded-[4px] cursor-pointer transition-all duration-300 hover:bg-[#f5f5f5] hover:border-[#4285F4]">
            <div class="flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="#4285F4"/>
              </svg>
            </div>
            <span class="text-[15px] text-[#333] font-medium">Arvada</span>
          </div>

          <!-- Centennial -->
          <div class="flex items-center gap-[12px] p-[12px] border border-[#e0e0e0] rounded-[4px] cursor-pointer transition-all duration-300 hover:bg-[#f5f5f5] hover:border-[#4285F4]">
            <div class="flex items-center justify-center">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="#4285F4"/>
              </svg>
            </div>
            <span class="text-[15px] text-[#333] font-medium">Centennial</span>
          </div>

        </div>
      </div>
    </div>

  </div>
</section>
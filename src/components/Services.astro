<style>
.services{
  background:#FFFDF1;
  padding:50px 20px;
}

.container{
  max-width:1100px;
  margin:auto;
}

.header{
  max-width:700px;
  margin-bottom:50px;
}

.header h2{
  color:black;
  margin-bottom:16px;
  font-family: 'Playfair Display', serif;
  font-size: 50px;
}

.header p{
  color:#5a6a7a;
  line-height:1.6;
  font-family: "DM Sans", sans-serif;
}

.header a{
  color:#2c6cb0;
  text-decoration:none;
}

.grid{
  display:grid;
  grid-template-columns:repeat(12, 1fr);
  grid-template-rows:repeat(2, 1fr);
  gap:24px;
  margin-bottom:40px;
  min-height: 400px;
}

.card {
  background: black;
  padding: 0;
  border-radius: 6px;
  border: 12px solid black;
  overflow: hidden;
  position: relative;
  transition: all 0.6s ease;
  display: flex;
  flex-direction: column;
}

.card:hover{
  transform: scale(1.02);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
}

.card-content {
  background: #000000;
  gap: 10px;
  padding: 10px;
  height: 100%;
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.6s ease;
}

.card:nth-child(1) {
  grid-column: 1 / 7;
  grid-row: 1 / 2;
}

.card:nth-child(2) {
  grid-column: 7 / 13;
  grid-row: 1 / 2;
}

.card:nth-child(3) {
  grid-column: 1 / 5;
  grid-row: 2 / 3;
}

.card:nth-child(4) {
  grid-column: 5 / 13;
  grid-row: 2 / 3;
}

.icon{
  font-size:24px;
  padding:10px;
  border-radius:4px;
}

.logo-banner {
    background: black;
    color: white;
    padding: 20px 40px;
}

.card h3 {
    font-family: "DM Sans", sans-serif;
  font-size: 22px;
  margin: 0;
  padding-bottom: 12px;
  color: #FFFDF1;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  background: none;
  position: relative;
  z-index: 1;
}

.card p{
  font-size:14px;
  color: #ffffff;
  transition: color 0.3s ease;
  font-family: "DM Sans", sans-serif;
}

.cta{
  text-align:center;
  font-family: "DM Sans", sans-serif;
}

.cta a{
  display:inline-block;
  border:2px solid #000000;
  padding:14px 28px;
  text-decoration:none;
  color:#000000;
  font-weight:600;
  border-radius:4px;
  transition: all 0.6s ease;
}

.cta a:hover{
  background:#000000;
  color:#FFFDF1;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
}

/* Responsive */

@media (max-width:768px){
  .grid{
    grid-template-columns:1fr;
    grid-template-rows: auto;
  }

  .card:nth-child(1),
  .card:nth-child(2),
  .card:nth-child(3),
  .card:nth-child(4) {
    grid-column: 1;
    grid-row: auto;
  }

  .header h2{
    font-size:26px;
  }
}
</style>
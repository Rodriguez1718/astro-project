<section class="services">
  <div class="container">

    <div class="header">
      <h2>Local Advertising Solutions for Denver Businesses</h2>
      <p>
        As your trusted <strong>Denver marketing pros</strong>, our
        <a href="#">billboard network</a> gives you access to high-traffic locations
        where your ideal customers spend time. From gyms and restaurants to retail
        stores and office buildings, we help you get noticed in the moments that matter.
      </p>
    </div>

    <div class="grid">

      <div class="card">
        <div class="icon">📺</div>
        <div>
          <h3>Indoor Billboard Advertising</h3>
          <p>High-impact advertising in premium indoor locations across Denver</p>
        </div>
      </div>

      <div class="card">
        <div class="icon">🔗</div>
        <div>
          <h3>Social Media Marketing</h3>
          <p>Build and engage your audience with strategic social media content</p>
        </div>
      </div>

      <div class="card">
        <div class="icon">🎨</div>
        <div>
          <h3>Custom Website Design</h3>
          <p>Professional websites that convert visitors into customers</p>
        </div>
      </div>

      <div class="card">
        <div class="icon">🎯</div>
        <div>
          <h3>Targeted Lead Generation</h3>
          <p>Strategic campaigns that generate quality leads and maximize ROI</p>
        </div>
      </div>

    </div>

    <div class="cta">
      <a href="#">Explore Our Digital Marketing Services</a>
    </div>

  </div>
</section>

<style>
.services{
  background:#FFFDF1;
  padding:80px 20px;
  font-family: system-ui, sans-serif;
}

.container{
  max-width:1100px;
  margin:auto;
}

.header{
  max-width:700px;
  margin-bottom:50px;
}

.header h2{
  font-size:32px;
  color:#0f2a44;
  margin-bottom:16px;
}

.header p{
  color:#5a6a7a;
  line-height:1.6;
}

.header a{
  color:#2c6cb0;
  text-decoration:none;
}

.grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:24px;
  margin-bottom:40px;
}

.card{
  display:flex;
  gap:16px;
  background:white;
  border:1px solid #e3e6ea;
  padding:24px;
  border-radius:6px;
  align-items:flex-start;
}

.icon{
  font-size:24px;
  border:2px solid #2c6cb0;
  padding:10px;
  border-radius:4px;
}

.card h3{
  font-size:16px;
  margin-bottom:6px;
  color:#0f2a44;
  text-transform:uppercase;
  letter-spacing:0.5px;
}

.card p{
  color:#6b7b8c;
  font-size:14px;
}

.cta{
  text-align:center;
}

.cta a{
  display:inline-block;
  border:2px solid #0f2a44;
  padding:14px 28px;
  text-decoration:none;
  color:#0f2a44;
  font-weight:600;
  border-radius:4px;
}

.cta a:hover{
  background:#0f2a44;
  color:white;
}

/* Responsive */

@media (max-width:768px){
  .grid{
    grid-template-columns:1fr;
  }

  .header h2{
    font-size:26px;
  }
}
</style>
<style>
h1 {
    font-family: 'Playfair Display', serif;
    font-size: 98px;
}

p {
    font-family: "DM Sans", sans-serif;
}

button{
  margin-top:20px;
  padding:12px 24px;
  border:none;
  background:white;
  color: black;
  cursor:pointer;
  transition: background 0.3s ease;
  text-transform: uppercase;
  letter-spacing: 3px;
}

button:hover {
    background: rgb(221, 221, 221);
}

.hero{
  padding: 100px 20px;
  text-align:center;
  color:white;
  height: 651px;
  max-height: 651px;
  display:flex;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}

.overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: black;
    opacity: 0.4;
    z-index: 1;
}

.container{
    display:flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    max-width:1200px;
	margin:auto;
	padding:20px;
    position: relative;
    z-index: 1;
}

.p-1 {
    font-weight: 700;
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 1rem;
}

.p-2 {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 1rem;
}

@media (max-width:768px){
	.hero{
		padding:60px 15px;
	}

	h1{
		font-size:28px;
	}
}

</style>
<section class="schedule">
  <div class="container">
    <div class="content">
      <h2>PARTNER WITH DENVER'S LOCAL ADVERTISING & DIGITAL MARKETING PROS</h2>
      <p>
        Whether you're looking for <strong>screen ads</strong>, a new <strong>website</strong>, or a complete <strong>digital marketing</strong> strategy in Denver, 
        we're here to help. Contact us today for a free consultation and let's discuss how we can grow your 
        business.
      </p>
      <button class="cta-button">SCHEDULE FREE CONSULTATION</button>
    </div>
  </div>
</section>

<style>
  .schedule {
    background: #C4A05A;
    padding: 80px 20px;
    font-family: "DM Sans", sans-serif;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .content {
    border: 2px solid white;
    padding: 60px 50px;
    border-radius: 4px;
  }

  h2 {
    color: white;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 24px;
    letter-spacing: 0.5px;
  }

  p {
    color: white;
    line-height: 1.8;
    margin-bottom: 32px;
    font-size: 16px;
  }

  .cta-button {
    padding: 14px 32px;
    background: white;
    border: none;
    color: #1a3a52;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
    border-radius: 2px;
  }

  .cta-button:hover {
    background: #f0f0f0;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .content {
      padding: 40px 30px;
    }

    h2 {
      font-size: 22px;
    }

    p {
      font-size: 15px;
    }
  }
</style>
